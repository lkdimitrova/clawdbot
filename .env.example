# clawdbot configuration
# Copy to .env and fill in your values:
#   cp .env.example .env

# ── Required ──────────────────────────────────────────────

# Space-separated list of GitHub repos to monitor (owner/repo format)
CLAWDBOT_REPOS="owner/repo-backend owner/repo-frontend"

# GitHub owner (used in GraphQL queries)
CLAWDBOT_GITHUB_OWNER="owner"

# Root directory containing your project repos
CLAWDBOT_PROJECTS_ROOT="$HOME/Projects"

# ── Branch Strategy ───────────────────────────────────────

# Integration branch (agents create PRs targeting this)
CLAWDBOT_INTEGRATION_BRANCH="development"

# Production branch (only humans merge here)
CLAWDBOT_MAIN_BRANCH="main"

# ── Paths ─────────────────────────────────────────────────

# Where clawdbot lives (this repo, after cloning to ~/.clawdbot)
CLAWDBOT_HOME="$HOME/.clawdbot"

# Node.js binary path (if using NVM or non-standard install)
CLAWDBOT_NODE_PATH="$HOME/.nvm/versions/node/v24.13.0/bin"

# ── Notifications ─────────────────────────────────────────

# How to notify on PR readiness (openclaw channel name)
CLAWDBOT_NOTIFY_CHANNEL="telegram"

# Chat/user ID for notifications (required — used by pr-manager and swarm-monitor)
CLAWDBOT_NOTIFY_TARGET=""

# Dependabot repo (skip auto-merge for Dependabot PRs in this repo)
# CLAWDBOT_DEPENDABOT_REPO="owner/repo-frontend"

# Repo path mapping (JSON, optional — maps repo names to local paths relative to CLAWDBOT_PROJECTS_ROOT)
# Default: repo name used as-is. Example: {"my-api": "myproject/api", "my-web": "myproject/web"}
# CLAWDBOT_REPO_MAP='{"repo-backend": "myproject/backend", "repo-frontend": "myproject/frontend"}'

# Model for review/CI-fix handlers (spawned by pr-manager)
CLAWDBOT_REVIEW_MODEL="anthropic/claude-opus-4-7"

# ── Agent Defaults ────────────────────────────────────────

# Default coding agent (codex|claude|gemini)
CLAWDBOT_DEFAULT_AGENT="codex"

# Default model for Codex agent
CLAWDBOT_CODEX_MODEL="gpt-5.3-codex"

# Default model for Claude Code agent
CLAWDBOT_CLAUDE_MODEL="claude-opus-4-7"

# Default model for Gemini CLI agent
CLAWDBOT_GEMINI_MODEL="gemini-2.5-pro"

# ── Agent Authentication ─────────────────────────────────────
# Preferred: use CLI OAuth login (codex auth / claude login / gemini auth).
# Agents inherit your OAuth session automatically — no keys needed.
#
# Alternative: set API keys here (for headless/CI environments).
# Only set the keys for agents you plan to use.

# OPENAI_API_KEY="sk-..."        # Codex CLI (if not using `codex auth`)
# ANTHROPIC_API_KEY="sk-ant-..." # Claude Code (if not using `claude login`)
# GEMINI_API_KEY="AIza..."       # Gemini CLI (if not using `gemini auth`)

# ── Optional ──────────────────────────────────────────────

# Agent skills repo path (for AGENTS.md enrichment)
# See: https://github.com/sickn33/antigravity-awesome-skills
CLAWDBOT_SKILLS_PATH="$CLAWDBOT_PROJECTS_ROOT/antigravity-awesome-skills/skills"
